{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "admin_booking/admin.html", "use": "@vercel/static" },
    { "src": "Resources/**", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/book", "destination": "/api/index.js" },
    { "source": "/api/bookings", "destination": "/api/index.js" },
    { "source": "/api/check-status/(.*)", "destination": "/api/index.js" },
    { "source": "/api/bookings/(.*)", "destination": "/api/index.js" }
  ]
}
